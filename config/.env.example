# ===========================================
# .env.example - Szablon zmiennych środowiskowych
# ===========================================
# Kancelaria Adwokacka Adwokat Katarzyna Maj
# ===========================================
#
# INSTRUKCJA:
# 1. Skopiuj ten plik jako .env
# 2. Uzupełnij wartości dla swojego środowiska
# 3. NIGDY nie commituj pliku .env do repozytorium!
#
# Przykład:
#   cp .env.example .env
#
# ===========================================

# ===========================================
# APLIKACJA
# ===========================================
APP_NAME="Kancelaria Adwokacka Katarzyna Maj"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# ===========================================
# DANE KANCELARII
# ===========================================
KANCELARIA_NAME="Kancelaria Adwokacka Adwokat Katarzyna Maj"
KANCELARIA_PHONE="+48 502 319 645"
KANCELARIA_EMAIL="biuro@adwokat-trzebnica.com"
KANCELARIA_ADDRESS="ul. Ignacego Daszyńskiego 67/4, 55-100 Trzebnica"
KANCELARIA_CITY="Trzebnica"
KANCELARIA_COUNTRY="Polska"
KANCELARIA_NIP="9680923753"
KANCELARIA_REGON="380051617"

# Godziny otwarcia (HH:MM-HH:MM)
KANCELARIA_HOURS_OPEN="09:00"
KANCELARIA_HOURS_CLOSE="17:00"
KANCELARIA_WORKING_DAYS="1,2,3,4,5"

# Współrzędne GPS
KANCELARIA_LATITUDE="51.3095"
KANCELARIA_LONGITUDE="17.0633"

# ===========================================
# BAZA DANYCH (MySQL)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=adwokat_user
DB_PASS=secure_password_123
DB_NAME=adwokat_db
DB_CHARSET=utf8mb4

# ===========================================
# KONFIGURACJA EMAIL
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=biuro@adwokat-trzebnica.com
MAIL_PASS=twoje_haslo_aplikacji
MAIL_FROM=biuro@adwokat-trzebnica.com
MAIL_FROM_NAME="Kancelaria Adwokacka Katarzyna Maj"
MAIL_ENCRYPTION=tls

# ===========================================
# USŁUGI GOOGLE
# ===========================================
GOOGLE_ANALYTICS_ID=G-W53VF82JQ6
GOOGLE_TAG_MANAGER_ID=GTM-T8BNX7QQ
GOOGLE_MAPS_API_KEY=AIzaSyDkH0926WzLC0Yz2nAOrulVatwRsISHxc4
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=

# ===========================================
# BEZPIECZEŃSTWO
# ===========================================
SESSION_LIFETIME=3600
CSRF_TOKEN_LENGTH=32
PASSWORD_HASH_ALGO=bcrypt
PASSWORD_HASH_COST=10

# Klucz szyfrujący (wygeneruj: openssl rand -hex 32)
APP_KEY=

# ===========================================
# PLIKI I UPLOADY
# ===========================================
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx,xls,xlsx
UPLOAD_DIR=/uploads

# ===========================================
# CACHE
# ===========================================
CACHE_DRIVER=file
CACHE_LIFETIME=3600

# ===========================================
# LOGOWANIE
# ===========================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_PATH=/logs

# ===========================================
# STREFA CZASOWA
# ===========================================
APP_TIMEZONE=Europe/Warsaw

# ===========================================
# DOKER (zmienne dla kontenerów)
# ===========================================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=adwokat_user
MYSQL_PASSWORD=secure_password_123
MYSQL_DATABASE=adwokat_db
MYSQL_INITDB_SKIP_TZINFO=yes

# ===========================================
# TYLKO DLA DEWELOPMENTU
# ===========================================
# Włącz dla szczegółowych komunikatów błędów
DEBUG_MODE=true
SHOW_ERRORS=true
SQL_LOG=false

# ===========================================
# PHPMAILER (dodatkowe opcje)
# ===========================================
MAIL_DEBUG=false
MAIL_TIMEOUT=30
MAIL_AUTH=true

# ===========================================
# COOKIE
# ===========================================
COOKIE_PREFIX=adwokat_
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Strict

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# ===========================================
# API KEYS (przyszłe integracje)
# ===========================================
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ===========================================
# SOCIAL MEDIA URLs
# ===========================================
SOCIAL_FACEBOOK=https://facebook.com/kancelaria-katarzyna-maj
SOCIAL_LINKEDIN=https://linkedin.com/in/katarzyna-maj-adwokat
SOCIAL_INSTAGRAM=https://instagram.com/kancelaria.katarzyna.maj

# ===========================================
# ANALYTICS & TRACKING
# ===========================================
FACEBOOK_PIXEL_ID=
GOOGLE_ADS_CONVERSION_ID=
HOTJAR_SITE_ID=

# ===========================================
# BACKUP
# ===========================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ===========================================
# PERFORMANCE
# ===========================================
OPCACHE_ENABLED=true
GZIP_COMPRESSION=true
BROWSER_CACHING=true

# ===========================================
# MAINTENANCE MODE
# ===========================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="Strona w trakcie konserwacji. Wrócimy wkrótce!"
